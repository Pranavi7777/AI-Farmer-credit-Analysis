# 🌾 AI Farmer Credit Intelligence Platform
# Environment Variables Configuration

# ===================================
# 🗄️ SUPABASE DATABASE (PostgreSQL)
# ===================================
# Get these from: https://app.supabase.com/project/_/settings/database
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
USE_POSTGRESQL=true

# ===================================
# 🚀 VERCEL BACKEND ENVIRONMENT
# ===================================
# Add these in Vercel dashboard -> Settings -> Environment Variables

FLASK_ENV=production
SECRET_KEY=your-super-secret-production-key-here
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
USE_POSTGRESQL=true

# ===================================
# 🌐 NETLIFY FRONTEND ENVIRONMENT  
# ===================================
# Add these in Netlify dashboard -> Site settings -> Build & deploy -> Environment variables

API_URL=https://your-backend-name.vercel.app

# ===================================
# 💾 LOCAL DEVELOPMENT
# ===================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Alekhya
DB_NAME=farmer_credit_ai
USE_POSTGRESQL=true

# ===================================
# 📋 SETUP INSTRUCTIONS
# ===================================

# 1. SUPABASE SETUP:
#    - Go to https://supabase.com
#    - Create new project: farmer-credit-ai
#    - Copy DATABASE_URL from Settings -> Database
#    - Run SQL script from DEPLOYMENT_GUIDE.md in SQL Editor

# 2. VERCEL BACKEND DEPLOYMENT:
#    - Install Vercel CLI: npm install -g vercel
#    - Run: vercel
#    - Add environment variables in Vercel dashboard
#    - Deploy: vercel --prod

# 3. NETLIFY FRONTEND DEPLOYMENT:
#    - Connect GitHub repo to Netlify
#    - Set build command: python build_frontend.py
#    - Set publish directory: dist
#    - Add environment variables
#    - Deploy

# 4. DATA MIGRATION:
#    - Run: python migrate_to_cloud.py
#    - Choose option 1 with Supabase connection string
#    - Or option 2 to export CSV files for manual import